# ================================
# Agent Firewall Environment File
# ================================

# --- Database ---
# The Docker Compose setup defaults to this Postgres instance.
DATABASE_URL="postgresql://firewall:secret@db:5432/firewalldb"

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:8001"

# --- Gateway Upstream APIs ---
# If your agents use the gateway to talk to OpenAI, set it here.
# LiteLLM will automatically read these variables when routing requests.
OPENAI_API_KEY="sk-your-openai-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
